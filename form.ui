  <property name="styleSheet">
   <string notr="true">#centralwidget {
	background-color: rgb(252, 252, 250);
}

#del, #newspaper_del, #printing_house_del, #newspapers_per_printing_house_del, #post_office_del, #newspapers_per_post_office_del, #del_7 {
	background-color: rgb(180, 56, 36);
	border-left: 20px solid rgb(134, 14, 19);
}

.QPushButton {
	color: rgb(255, 255, 255);
	border: none;
	text-align: left;
	border-left: 20px solid rgb(58, 90, 64);
	padding: 8px 8px;
	background-color: rgb(88, 129, 87);
}

.QPushButton:hover {
	background-color: rgb(58, 90, 64);
	border-right: 5px solid rgba(0,0,0, 0.2);
	border-left: none;
}

#del:hover, #newspaper_del:hover, #printing_house_del:hover, #newspapers_per_printing_house_del:hover, #post_office_del:hover, #newspapers_per_post_office_del:hover, #del_7:hover {
	background-color: rgb(134, 14, 19);
	border-right: 5px solid rgba(0,0,0, 0.2);
	border-left: none;
}

.QLineEdit {
	background-color: rgb(246, 245, 244);
	border: none;
	padding: 5px 10px;
	color: rgb(77, 77, 77);
}
.QSpinBox, .QDoubleSpinBox {
	background-color: rgb(246, 245, 244);
	border: none;
	padding: 5px 10px;
	color: rgb(77, 77, 77);
}
.QComboBox {
	background-color: rgb(246, 245, 244);
	border: none;
	padding: 5px 10px;
	color: rgb(77, 77, 77);
}

QComboBox::down-arrow {
	border:0px;
	
}
QComboBox::drop-down {
	border:0px;
	
}



QListWidget::item:selected {
	color:white;
	font-weight: 900;
	background-color: rgb(70, 120, 80);
	border-left: 5px solid rgba(0,0,0, 0.2);
	
}

QListWidget::item::hover {
	color:white;
	background-color: rgb(80, 130, 90);
}

QPushButton:disabled {
    background-color: rgb(232,232,232);
	border-left: 20px solid rgb(220,220,220);
	color: rgb(190, 190, 190);

}</string>
